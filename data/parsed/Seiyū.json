linkAnchor": "Links"}, {"toclevel": 1, "level": "2", "line": "References", "number": "2", "index": "2", "fromtitle": "Seiyū", "byteoffset": 3782, "anchor": "References", "linkAnchor": "References"}], "categories": ["A to Z", "Seiyū"], "infobox": {}, "templates": ["reflist", "stub"], "internal_links": ["Gendo Ikari", "Rei Ayanami", "Toji Suzuhara", "Misato Katsuragi", "Mugihito", "Yui Ikari", "Koichi Yamadera", "Shigeru Aoba", "Pen Pen", "Tomokazu Seki", "Kaworu Nagisa", "Yuko Miyamura", "Hikari Horaki", "Makoto Hyuga", "Megumi Ogata", "Maya Ibuki", "Motomu Kiyokawa", "Kensuke Aida", "Fumihiko Tachiki", "Tetsuya Iwanaga", "Junko Iwao", "Asuka Langley Soryu ", "Kotono Mitsuishi", "Eva-01", "Keel Lorenz", "Akira Ishida", "Yuriko Yamaguchi", "Kozo Fuyutsuki", "Miki Nagasawa", "Shinji Ikari", "Ritsuko Akagi", "Hiro Yuki", "Ryoji Kaji", "Takehito Koyasu", "Megumi Hayashibara"], "external_links": ["http://en.wikipedia.org/wiki/Category:Japanese_voice_actor_management_companies", "http://www.riuva.com/?p=111", "http://www.animenewsnetwork.com/encyclopedia/people.php?id=391", "http://atemonai.com/blog/seiyuu-glossary/", "http://en.wikipedia.org/wiki/Seiyu", "http://www.animenewsnetwork.com/encyclopedia/people.php", "http://www.usagi.org/~doi/seiyuu/"], "iw_links": [], "lang_links": [], "properties": [], "protection": [], "rev_id": 49972, "length_bytes": null, "parse_warnings": [], "touched_at": null, "references": [{"ref_name": null, "content": "http://en.wikipedia.org/wiki/Category:Japanese_voice_actor_management_companies", "url": "http://en.wikipedia.org/wiki/Category:Japanese_voice_actor_management_companies", "position": 0}, {"ref_name": null, "content": "http://www.riuva.com/?p=111", "url": "http://www.riuva.com/?p=111", "position": 1}, {"ref_name": null, "content": "[http://www.animenewsnetwork.com/encyclopedia/people.php?id=391 ANN credits list for Hayashibara]", "url": "http://www.animenewsnetwork.com/encyclopedia/people.php?id=391", "position": 2}], "chunks": [{"article_slug": "Seiyū", "section": "", "content": "\"Seiyū\" is the Japanese term for \"voice actor\", and are also called \"character voice\" (CV). In conventional usage, \"seiyū\" refers to the original Japanese voice actor for an anime role, while the provider of the English dub for the role is referred to as the \"Voice actor\".\n\nGenerally, seiyū receive much more recognition for their roles in Japan, sometimes achieving national fame, than their English voice acting counterparts. Like most voice actors, they take different types of voice work, anywhere from anime, to announcing arrivals and departures at train stations, television commercial (CM) voice-overs, narration, automobile satnav devices, and dubbing Western films and television shows.\n\nSome seiyu have diversified into other endeavors, such as singing, stage-acting, and live-action film acting. In addition they are also into talk radio as radio personalities. \n\nWith the exception of a few freelancers, most seiyuu are organized under management agencies.http://en.wikipedia.org/wiki/Category:Japanese_voice_actor_management_companies\n\nDespite this, they are by all accounts shockingly underpaid, often having to take a second job in order to make ends meet.http://www.riuva.com/?p=111 \n\n'''NGE Major Character Seiyū\n\n Character Seiyū ImageSeiyūImageShinji IkariMegumi Ogata200px200pxMisato KatsuragiKotono Mitsuishi200px200pxAsuka Langley Soryu Yuko Miyamura200px200pxRei Ayanami, Yui Ikari, Pen Pen and Eva-01(berserk)ANN credits list for Hayashibara Megumi Hayashibara200px\n200px\n200px\n200px200pxGendo IkariFumihiko Tachiki200px200pxRitsuko AkagiYuriko Yamaguchi200px200pxRyoji KajiKoichi Yamadera200px200pxKozo FuyutsukiMotomu Kiyokawa200px200pxKaworu NagisaAkira Ishida200px200pxKeel LorenzMugihito200px200pxKensuke AidaTetsuya Iwanaga200px200pxToji SuzuharaTomokazu Seki200px200pxHikari HorakiJunko Iwao200px200pxMaya IbukiMiki Nagasawa200px200pxMakoto HyugaH", "position": 0, "token_count": 512}, {"article_slug": "Seiyū", "section": "", "content": "200pxToji SuzuharaTomokazu Seki200px200pxHikari HorakiJunko Iwao200px200pxMaya IbukiMiki Nagasawa200px200pxMakoto HyugaHiro Yuki200px200pxShigeru AobaTakehito Koyasu200px200px\n\nLinks\nj1m0ne's Blog - Seiyuu Glossary\nSeiyuu @ Wikipedia\nANN People Database\nSeiyuu (Voice Actor) Database\n\nReferences\n\nCategory:A to Z\nCategory:Seiyū", "position": 1, "token_count": 120}]}